# Copy this to .env and fill in your values

# Database — SQLite is the default, no installation needed!
DATABASE_URL=sqlite:///./ai_efficiency.db
# To use PostgreSQL instead (optional):
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_efficiency

# Redis (optional - for caching)
REDIS_URL=redis://localhost:6379

# AI API Keys (add at least one)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# JWT Secret (change this to a random string)
SECRET_KEY=your-secret-key-change-this-in-production

# Server
HOST=0.0.0.0
PORT=8000
